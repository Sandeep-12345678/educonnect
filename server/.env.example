# ============================================
# EduConnect OAuth Provider Credentials
# ============================================
# Add your real credentials below.
# Restart server after changes.
# ============================================

# Server
JWT_SECRET=educonnect-secret-change-in-production
PORT=3001

# Google OAuth (https://console.cloud.google.com/apis/credentials)
# Create OAuth 2.0 Client ID → Web application
# Authorized redirect: https://your-domain.com/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub OAuth (https://github.com/settings/developers)
# New OAuth App → Homepage URL + callback
# Callback: https://your-domain.com/auth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Apple Sign In (https://developer.apple.com/account/resources/services)
# Certificates, Identifiers & Profiles → Service IDs
# Return URL: https://your-domain.com/auth/apple/callback
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=

# Microsoft (https://portal.azure.com → App registrations)
# Redirect URI: https://your-domain.com/auth/microsoft/callback
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# Discord (https://discord.com/developers/applications)
# Redirects: https://your-domain.com/auth/discord/callback
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# App URL (change for production)
APP_URL=http://localhost:5173
